datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Core ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
}

// ── Clients ─────────────────────────────────────────────────────────────────

model Client {
  id                  String    @id @default(cuid())
  name                String
  industry            String?
  size                String?
  status              String    @default("active")
  tier                String?
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  logo                String?
  notes               String?
  mrr                 Float     @default(0)
  contractStart       DateTime?
  contractEnd         DateTime?
  forecastCallPercent Float?
  forecastReason      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  journeyPhases    JourneyPhase[]
  valueOutcomes    ValueOutcome[]
  scoreSnapshots   ScoreSnapshot[]
  services         ClientService[]
  tasks            Task[]
  activities       Activity[]
  accountPlanItems AccountPlanItem[]
}

// ── Cyber Journey ───────────────────────────────────────────────────────────

model JourneyPhase {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phase       String
  status      String    @default("not_started")
  order       Int
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── 6 Value Outcomes ────────────────────────────────────────────────────────

model ValueOutcome {
  id       String   @id @default(cuid())
  clientId String
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category String
  score    Int      @default(0)
  notes    String?
  updatedAt DateTime @updatedAt
}

// ── Score Tracking ──────────────────────────────────────────────────────────

model ScoreSnapshot {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  overallScore     Int
  riskReduction    Int      @default(0)
  compliance       Int      @default(0)
  resilience       Int      @default(0)
  dataProtection   Int      @default(0)
  incidentResponse Int      @default(0)
  securityCulture  Int      @default(0)
  capturedAt       DateTime @default(now())
}

// ── Services ────────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  createdAt   DateTime @default(now())

  clients ClientService[]
}

model ClientService {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status    String   @default("opportunity")
  revenue   Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, serviceId])
}

// ── Tasks ───────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Account Plan ────────────────────────────────────────────────────────────

model AccountPlanItem {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  task        String
  description String?
  dueDate     DateTime?
  roi         String?
  comments    String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Activity Log ────────────────────────────────────────────────────────────

model Activity {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  type      String
  title     String
  details   String?
  createdAt DateTime @default(now())
}
