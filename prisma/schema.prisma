datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  businessName    String?
  address         String?
  phone           String?
  website         String?
  logoUrl         String?
  defaultRate     Float    @default(150)
  defaultTerms    String   @default("Net 30")
  taxId           String?
  goalAnnualRev   Float?
  goalMonthlyHrs  Float?
  createdAt       DateTime @default(now())
}

model Client {
  id              String    @id @default(cuid())
  name            String
  status          String    @default("Prospect")
  industry        String?
  website         String?
  companySize     String?
  source          String?
  referredById    String?
  referredBy      Client?   @relation("Referrals", fields: [referredById], references: [id])
  referrals       Client[]  @relation("Referrals")
  notes           String?
  mrr             Float     @default(0)
  contractValue   Float     @default(0)
  healthScore         Int       @default(50)
  engagementScore     Int       @default(50)
  satisfactionScore   Int?
  paymentScore        Int       @default(100)
  adoptionScore       Int?
  csmPulse            Int       @default(50)
  lastHealthUpdate    DateTime?
  onboardedAt     DateTime?
  firstValueAt    DateTime?
  lastContactAt   DateTime?
  nextQbrDate     DateTime?
  churnedAt       DateTime?
  churnReason     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  contacts        Contact[]
  deals           Deal[]
  tasks           Task[]
  timeEntries     TimeEntry[]
  invoices        Invoice[]
  contracts       Contract[]
  activities      Activity[]
  proposals       Proposal[]
  goals           ClientGoal[]

  @@index([status])
}

model Contact {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String
  title           String?
  email           String?
  phone           String?
  role            String?
  sentiment       String?
  isPrimary       Boolean  @default(false)
  isExecutive     Boolean  @default(false)
  notes           String?
  lastContactAt   DateTime?
  linkedinUrl     String?
  birthday        String?
  interests       String?
  createdAt       DateTime @default(now())
  activities      Activity[]

  @@index([clientId])
}

model Deal {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  value           Float
  stage           String    @default("Lead")
  probability     Int       @default(10)
  closeDate       DateTime?
  actualCloseDate DateTime?
  notes           String?
  lostReason      String?
  winFactors      String?
  nextStep        String?
  proposalId      String?
  proposal        Proposal? @relation(fields: [proposalId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  stageHistory    StageChange[]

  @@index([clientId])
  @@index([stage])
}

model StageChange {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage String
  toStage   String
  changedAt DateTime @default(now())
  notes     String?

  @@index([dealId])
}

model Task {
  id              String    @id @default(cuid())
  title           String
  description     String?
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  priority        String    @default("Medium")
  status          String    @default("open")
  category        String?
  dueDate         DateTime?
  completedAt     DateTime?
  recurring       String?
  nextRecurrence  DateTime?
  playbook        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
  @@index([dueDate])
  @@index([status])
}

model TimeEntry {
  id              String   @id @default(cuid())
  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  description     String
  hours           Float
  rate            Float
  date            DateTime
  category        String?
  invoiceId       String?
  invoice         Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  billable        Boolean  @default(true)
  timerStart      DateTime?
  createdAt       DateTime @default(now())

  @@index([clientId])
  @@index([date])
}

model Invoice {
  id              String      @id @default(cuid())
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  number          String      @unique
  amount          Float
  tax             Float       @default(0)
  status          String      @default("Draft")
  issuedDate      DateTime
  dueDate         DateTime
  paidDate        DateTime?
  paymentMethod   String?
  notes           String?
  terms           String?
  reminderSentAt  DateTime?
  lineItems       InvoiceLineItem[]
  timeEntries     TimeEntry[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([clientId])
  @@index([status])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  amount      Float
  timeEntryId String?
  sortOrder   Int      @default(0)
}

model Contract {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  type            String
  status          String    @default("Draft")
  startDate       DateTime?
  endDate         DateTime?
  value           Float?
  monthlyValue    Float?
  renewalType     String?
  renewalTerms    String?
  reminderDays    Int       @default(30)
  autoRenewDate   DateTime?
  terminationClause String?
  fileUrl         String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([endDate])
}

model Activity {
  id              String   @id @default(cuid())
  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId          String?
  type            String
  title           String
  description     String?
  date            DateTime @default(now())
  duration        Int?
  outcome         String?
  sentiment       String?
  isKeyMoment     Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([clientId])
  @@index([date])
}

model Proposal {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  status          String   @default("Draft")
  type            String   @default("Proposal")
  executiveSummary String?
  problemStatement String?
  scopeOfWork     String?
  timeline        String?
  investment      Float?
  paymentTerms    String?
  validUntil      DateTime?
  sentAt          DateTime?
  acceptedAt      DateTime?
  declinedReason  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deliverables    ProposalDeliverable[]
  deals           Deal[]
}

model ProposalDeliverable {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  title       String
  description String?
  sortOrder   Int      @default(0)
}

model ClientGoal {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  targetMetric    String?
  targetValue     Float?
  currentValue    Float?
  status          String   @default("In Progress")
  dueDate         DateTime?
  achievedAt      DateTime?
  quarter         String?
  notes           String?
  createdAt       DateTime @default(now())
}

model Playbook {
  id              String   @id @default(cuid())
  name            String
  description     String?
  trigger         String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  steps           PlaybookStep[]
}

model PlaybookStep {
  id          String   @id @default(cuid())
  playbookId  String
  playbook    Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  title       String
  dayOffset   Int      @default(0)
  taskTemplate String?
  sortOrder   Int      @default(0)
}

model Template {
  id              String   @id @default(cuid())
  name            String
  category        String
  subject         String?
  body            String
  variables       String?
  createdAt       DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  frequency   String   @default("monthly")
  category    String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
}

model HealthScoreSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  score       Int
  engagement  Int
  satisfaction Int?
  payment     Int
  adoption    Int?
  csmPulse    Int
  recordedAt  DateTime @default(now())

  @@index([clientId])
}

model MetricSnapshot {
  id          String   @id @default(cuid())
  metric      String
  value       Float
  recordedAt  DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  changes     String
  performedAt DateTime @default(now())
}
